# Backend (Render dashboard or local repo root .env)
GEMINI_API_KEY=
DATABASE_URL=sqlite:///./.data/claims.db
# Comma-separated exact origins (optional if CORS_ORIGIN_REGEX is set)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Allow all Vercel preview + production URLs
CORS_ORIGIN_REGEX=https://.*\.vercel\.app

# Frontend (Vercel dashboard or frontend/.env.local)
# NEXT_PUBLIC_API_URL=https://plum-claims-api.onrender.com
